<div class="d-flex flex-column my-3 mb-5">

    {% if product_signs %}

        {# <li> #}
        {#    <hr class="dropdown-divider"> #}
        {# </li> #}


        <div class="d-flex gap-3 align-items-center justify-content-between w-100 mb-3">
            <h5 class="text-uppercase fw-bolder py-2">Честный знак</h5>

            <a class="btn btn-sm btn-light disabled prnt text-muted text-nowrap"
               data-bs-toggle="modal"
               data-bs-target="#modal"
               href="{{ path('products-supply:document.sign.print', { supply: id }) }}">

                Печать всех честных знаков &nbsp;

                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                     fill="currentColor"
                     class="bi bi-printer" viewBox="0 0 16 16">
                    <path d="M2.5 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1"/>
                    <path d="M5 1a2 2 0 0 0-2 2v2H2a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1v1a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1V3a2 2 0 0 0-2-2zM4 3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2H4zm1 5a2 2 0 0 0-2 2v1H2a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v-1a2 2 0 0 0-2-2zm7 2v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1"/>
                </svg>
            </a>
        </div>


        {# Честные знаки #}

        {# @var product \BaksDev\Products\Supply\Repository\ProductSign\GroupProductSignsByProductSupply\GroupProductSignsByProductSupplyResult #}
        {% for product in product_signs %}


            {% set pdf_url = path('products-supply:document.sign.pdf', {
                supply: id,
                article: product.productArticle,
                part: product.signPart,
                product: product.productId,
                offer: product.productOfferConst,
                variation: product.productVariationConst,
                modification: product.productModificationConst,
            }) %}


            <div class="dropdown-item">
                <div class="d-flex gap-3 align-items-center">

                    <div class="w-100">

                        {{ product.getCounter }} шт. &nbsp;

                        {{ product.productName }}

                        {# Значение множественного варианта ТП #}
                        {{ product.productVariationValue|call_twig_func(product.productVariationReference~'_render') ~
                        product.productModificationValue|call_twig_func(product.productModificationReference~'_render') }}

                        {# Значение торгового предложения #}
                        {{ product.productOfferValue|call_twig_func(product.productOfferReference~'_render') }}

                        {{ product.productOfferPostfix }}
                        {{ product.productVariationPostfix }}
                        {{ product.productModificationPostfix }}

                    </div>

                    {# СКАЧАТЬ #}
                    <div class="d-flex gap-3 align-items-center ">

                        {# PDF #}
                        <a class="text-muted"
                           href="{{ pdf_url }}">

                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                                 fill="currentColor" class="bi bi-filetype-pdf"
                                 viewBox="0 0 16 16">
                                <path fill-rule="evenodd"
                                      d="M14 4.5V14a2 2 0 0 1-2 2h-1v-1h1a1 1 0 0 0 1-1V4.5h-2A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v9H2V2a2 2 0 0 1 2-2h5.5zM1.6 11.85H0v3.999h.791v-1.342h.803q.43 0 .732-.173.305-.175.463-.474a1.4 1.4 0 0 0 .161-.677q0-.375-.158-.677a1.2 1.2 0 0 0-.46-.477q-.3-.18-.732-.179m.545 1.333a.8.8 0 0 1-.085.38.57.57 0 0 1-.238.241.8.8 0 0 1-.375.082H.788V12.48h.66q.327 0 .512.181.185.183.185.522m1.217-1.333v3.999h1.46q.602 0 .998-.237a1.45 1.45 0 0 0 .595-.689q.196-.45.196-1.084 0-.63-.196-1.075a1.43 1.43 0 0 0-.589-.68q-.396-.234-1.005-.234zm.791.645h.563q.371 0 .609.152a.9.9 0 0 1 .354.454q.118.302.118.753a2.3 2.3 0 0 1-.068.592 1.1 1.1 0 0 1-.196.422.8.8 0 0 1-.334.252 1.3 1.3 0 0 1-.483.082h-.563zm3.743 1.763v1.591h-.79V11.85h2.548v.653H7.896v1.117h1.606v.638z"/>
                            </svg>
                        </a>

                        {# TXT small #}
                        <a class="text-muted" title="Скачать TXT c короткой кодировкой"
                           href="{{ path('products-supply:document.sign.text', {
                               size: 'small',
                               supply: id,
                               article: product.productArticle,
                               part: product.signPart,
                               product: product.productId,
                               offer: product.productOfferConst,
                               variation: product.productVariationConst,
                               modification: product.productModificationConst,
                           }) }}">

                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                                 fill="currentColor" class="bi bi-filetype-txt"
                                 viewBox="0 0 16 16">
                                <path fill-rule="evenodd"
                                      d="M14 4.5V14a2 2 0 0 1-2 2h-2v-1h2a1 1 0 0 0 1-1V4.5h-2A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v9H2V2a2 2 0 0 1 2-2h5.5zM1.928 15.849v-3.337h1.136v-.662H0v.662h1.134v3.337zm4.689-3.999h-.894L4.9 13.289h-.035l-.832-1.439h-.932l1.228 1.983-1.24 2.016h.862l.853-1.415h.035l.85 1.415h.907l-1.253-1.992zm1.93.662v3.337h-.794v-3.337H6.619v-.662h3.064v.662H8.546Z"/>
                            </svg>
                        </a>

                        {# TXT big #}
                        <a class="text-muted" title="Скачать TXT c полной кодировкой"
                           href="{{ path('products-supply:document.sign.text', {
                               size: 'big',
                               supply: id,
                               part: product.signPart,
                               article: product.productArticle,
                               product: product.productId,
                               offer: product.productOfferConst,
                               variation: product.productVariationConst,
                               modification: product.productModificationConst
                           }) }}">

                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                                 fill="currentColor"
                                 class="bi bi-file-earmark-text" viewBox="0 0 16 16">
                                <path d="M5.5 7a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1zM5 9.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0 2a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5"/>
                                <path d="M9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.5zm0 1v2A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1z"/>
                            </svg>
                        </a>
                    </div>

                </div>

            </div>

        {% endfor %}

    {% else %}
        <h6 class="dropdown-header">Честных знаков не найдено</h6>
    {% endif %}

</div>

<hr>

<div class="clearfix d-flex gap-3 align-items-center my-3">
    <strong class="text-nowrap">Загрузить файлы PDF с честными знаками для добавления в поставку</strong>
    <div class="w-100">
        <hr class="m-0">
    </div>
</div>

<div class="card-body pb-0" id='{{ form.files.vars.id }}-collection'>

    {% for file in form.files.files %}

        <div class='d-flex align-items-center gap-3 mb-3'>

            <div class="input-group w-100">

                {{ form_widget(file.files) }}

                <span class="input-group-text">

                    {# PDF icon #}
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                         class="bi bi-filetype-pdf" viewBox="0 0 16 16">
                        <path fill-rule="evenodd"
                              d="M14 4.5V14a2 2 0 0 1-2 2h-1v-1h1a1 1 0 0 0 1-1V4.5h-2A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v9H2V2a2 2 0 0 1 2-2h5.5L14 4.5ZM1.6 11.85H0v3.999h.791v-1.342h.803c.287 0 .531-.057.732-.173.203-.117.358-.275.463-.474a1.42 1.42 0 0 0 .161-.677c0-.25-.053-.476-.158-.677a1.176 1.176 0 0 0-.46-.477c-.2-.12-.443-.179-.732-.179Zm.545 1.333a.795.795 0 0 1-.085.38.574.574 0 0 1-.238.241.794.794 0 0 1-.375.082H.788V12.48h.66c.218 0 .389.06.512.181.123.122.185.296.185.522Zm1.217-1.333v3.999h1.46c.401 0 .734-.08.998-.237a1.45 1.45 0 0 0 .595-.689c.13-.3.196-.662.196-1.084 0-.42-.065-.778-.196-1.075a1.426 1.426 0 0 0-.589-.68c-.264-.156-.599-.234-1.005-.234H3.362Zm.791.645h.563c.248 0 .45.05.609.152a.89.89 0 0 1 .354.454c.079.201.118.452.118.753a2.3 2.3 0 0 1-.068.592 1.14 1.14 0 0 1-.196.422.8.8 0 0 1-.334.252 1.298 1.298 0 0 1-.483.082h-.563v-2.707Zm3.743 1.763v1.591h-.79V11.85h2.548v.653H7.896v1.117h1.606v.638H7.896Z"/>
                    </svg>

                    {# xlsx icon #}
                    {# &nbsp; #}
                    {# <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" #}
                    {# class="bi bi-filetype-xlsx" viewBox="0 0 16 16"> #}
                    {# <path fill-rule="evenodd" #}
                    {# d="M14 4.5V11h-1V4.5h-2A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v9H2V2a2 2 0 0 1 2-2h5.5zM7.86 14.841a1.13 1.13 0 0 0 .401.823q.195.162.479.252.284.091.665.091.507 0 .858-.158.355-.158.54-.44a1.17 1.17 0 0 0 .187-.656q0-.336-.135-.56a1 1 0 0 0-.375-.357 2 2 0 0 0-.565-.21l-.621-.144a1 1 0 0 1-.405-.176.37.37 0 0 1-.143-.299q0-.234.184-.384.188-.152.513-.152.214 0 .37.068a.6.6 0 0 1 .245.181.56.56 0 0 1 .12.258h.75a1.1 1.1 0 0 0-.199-.566 1.2 1.2 0 0 0-.5-.41 1.8 1.8 0 0 0-.78-.152q-.44 0-.777.15-.336.149-.527.421-.19.273-.19.639 0 .302.123.524t.351.367q.229.143.54.213l.618.144q.31.073.462.193a.39.39 0 0 1 .153.326.5.5 0 0 1-.085.29.56.56 0 0 1-.255.193q-.168.07-.413.07-.176 0-.32-.04a.8.8 0 0 1-.249-.115.58.58 0 0 1-.255-.384zm-3.726-2.909h.893l-1.274 2.007 1.254 1.992h-.908l-.85-1.415h-.035l-.853 1.415H1.5l1.24-2.016-1.228-1.983h.931l.832 1.438h.036zm1.923 3.325h1.697v.674H5.266v-3.999h.791zm7.636-3.325h.893l-1.274 2.007 1.254 1.992h-.908l-.85-1.415h-.035l-.853 1.415h-.861l1.24-2.016-1.228-1.983h.931l.832 1.438h.036z"/> #}
                    {# </svg> #}
                </span>

            </div>
        </div>

    {% endfor %}

</div>

{% set prototype_file = include(_self|replace({ "files.html.twig": "prototype.file.html.twig" }) )|e('html_attr') %}

<button
        type="button"
        class="btn btn-sm btn-outline-primary border-0 mb-3"
        id="file-add-collection"
        data-prototype="{{ prototype_file|raw }}"
        data-collection="{{ form.files.vars.id }}-collection"
        data-index="{{ form.files.count }}"
>

    <span class="svg-icon svg-icon-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <rect opacity="0.5" x="11" y="18" width="12" height="2" rx="1" transform="rotate(-90 11 18)"
                  fill="currentColor">
            </rect>
            <rect x="6" y="11" width="12" height="2" rx="1" fill="currentColor"></rect>
        </svg>
    </span>

    Добавить еще файл
</button>